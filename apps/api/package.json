{
  "name": "@envoy/api",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "bun --env-file=../../.env run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun --env-file=../../.env run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@envoy/db": "workspace:*",
    "@envoy/types": "workspace:*",
    "@hono/zod-validator": "^0.5.0",
    "@privy-io/server-auth": "^1.32.5",
    "hono": "^4.7.6",
    "jose": "^6.1.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "typescript": "^5.8.2"
  }
}
