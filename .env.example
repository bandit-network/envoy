# ============================
# Privy
# ============================
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Public Privy app ID (exposed to browser via Next.js)
NEXT_PUBLIC_PRIVY_APP_ID=

# ============================
# Envoy Identity Signing
# ============================
# Private key for signing agent identity manifests (PEM or JWK)
ENVOY_ISSUER_PRIVATE_KEY=
# Key ID published in /.well-known/envoy-issuer JWKS
ENVOY_ISSUER_KEY_ID=

# ============================
# Database
# ============================
DATABASE_URL=postgresql://envoy:envoy@localhost:5432/envoy

# ============================
# Redis
# ============================
REDIS_URL=redis://localhost:6379

# ============================
# Webhooks
# ============================
# HMAC-SHA256 secret for signing webhook payloads to platforms
WEBHOOK_SIGNING_SECRET=

# ============================
# App Config
# ============================
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000

# Base URL for the API (used by the web app BFF and SDK)
API_BASE_URL=http://localhost:3001

# Public API base URL (exposed to browser for client-side fetch)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Base URL for the web app (used for CORS, redirects)
WEB_BASE_URL=http://localhost:3000

# ============================
# Token Defaults
# ============================
# Default token TTL in seconds (3600 = 1 hour)
TOKEN_DEFAULT_TTL=3600
# Maximum allowed TTL in seconds (86400 = 24 hours)
TOKEN_MAX_TTL=86400
# Pairing secret TTL in seconds (600 = 10 minutes)
PAIRING_SECRET_TTL=600

# ============================
# Wallet Provisioning
# ============================
# Enable Privy agentic wallet provisioning on agent creation
WALLET_PROVISIONING_ENABLED=false

# ============================
# 8004 Solana Agent Registry
# ============================
# Enable on-chain agent registration
REGISTRY_ENABLED=false
# Base58-encoded private key for signing registry transactions
REGISTRY_SIGNER_PRIVATE_KEY=
# Solana cluster: devnet | mainnet-beta
REGISTRY_CLUSTER=devnet
# Custom Solana RPC URL (optional, defaults to public RPC)
REGISTRY_RPC_URL=
# Collection pointer for grouping agents (format: c1:<payload>)
# Generate via POST /api/v1/agents/registry/init-collection
REGISTRY_COLLECTION_POINTER=
# Pinata JWT for uploading agent metadata to IPFS
PINATA_JWT=

# ============================
# Rate Limiting
# ============================
# Max requests per minute for public endpoints
RATE_LIMIT_PUBLIC=60
# Max requests per minute for authenticated endpoints
RATE_LIMIT_AUTHENTICATED=120
# Max requests per minute for platform verification endpoint
RATE_LIMIT_VERIFY=300
